# ─── Stripe Connect ───────────────────────────────────────────────────────────
# Found at https://dashboard.stripe.com/apikeys

# Secret key — server-side only, never expose to the browser
STRIPE_SECRET_KEY=sk_test_...

# Publishable key — safe to embed in client-side code
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — obtained from the Stripe Dashboard (Developers → Webhooks)
# or from the Stripe CLI: `stripe listen --print-secret`
STRIPE_WEBHOOK_SECRET=whsec_...
