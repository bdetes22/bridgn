# ─── Stripe Connect ───────────────────────────────────────────────────────────
# Found at https://dashboard.stripe.com/apikeys

# Secret key — server-side only, never expose to the browser
STRIPE_SECRET_KEY=sk_test_...

# Publishable key — safe to embed in client-side code
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — obtained from the Stripe Dashboard (Developers → Webhooks)
# or from the Stripe CLI: `stripe listen --print-secret`
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found at https://supabase.com/dashboard → your project → Settings → API

# Public project URL (safe to expose)
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role key — server-side only, bypasses Row Level Security
SUPABASE_SERVICE_KEY=eyJ...

# ─── Server ───────────────────────────────────────────────────────────────────

# Public URL of this server (used to build Stripe return/refresh URLs)
# In production: https://api.bridgn.app or https://bridgn.app
APP_URL=http://localhost:3000

# URL of the frontend app (may differ from APP_URL in split deployments)
CLIENT_URL=http://localhost:3000

# Port the Express server listens on (default: 3000)
PORT=3000
